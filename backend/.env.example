# Server port
PORT=5000

# MongoDB connection (replace with your URI)
MONGODB_URI=
MONGODB_DB_NAME=survly

# JWT secret (do NOT commit real secrets)
JWT_SECRET=

# Comma-separated allowed origins for CORS (e.g. https://yourdomain.com)
ALLOWED_ORIGINS=

# Optional: Use AWS S3 for uploaded files instead of local disk.
# If you enable S3, set these values on your hosting provider (do NOT commit secrets).
# Set either S3_BUCKET + AWS credentials, or leave empty to use local `uploads/` folder.
# Example:
# S3_BUCKET=your-bucket-name
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# To explicitly enable S3 usage, set USE_S3=true (optional).
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
USE_S3=